# Database
DATABASE_URL=postgresql://dev:dev@localhost:5432/smartgenerate

# Redis (used in Phase 5 for BullMQ queue)
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change-me-to-a-long-random-string-in-production

# Google OAuth
# Get these from: https://console.cloud.google.com
# → APIs & Services → Credentials → Create OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Storage (local disk for now, swap to R2 in production)
STORAGE_PATH=./uploads

# URLs
FRONTEND_URL=http://localhost:5173
PORT=3000

# Environment
NODE_ENV=development
